{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "jsx": "react-jsx", //ts-loader does handle tsx files
        "lib": ["DOM", "ES6"],
        "target": "es6",
        //dont forget options include, exclude, types, path

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        // module: nodenext, require stricter module system hybrid module kind (Node16/18/Next) is only supported in "isolatedModules: true"
        // Now we using baseUrl, all import should resolve from this
        "isolatedModules": true,
        //This resolution has higher priority than lookups from node_modules.
        "baseUrl": ".",
        // relative to the baseUrl if set, or to the tsconfig file itself otherwise
        "paths": {
            "@/*": ["./src/*"]
        }
    }
}
