{
    "compilerOptions": {
        "rootDir": "./src",
        "outDir": "./dist",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "jsx": "react-jsx", //ts-loader does handle tsx files
        "lib": ["DOM", "ES6"],
        "target": "es6",
        //dont forget options include, exclude, types, path

        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,

        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    }
}
